# Copia a .env.local:  copy .env.example .env.local

# --- Neon PostgreSQL ---
DATABASE_URL=

# --- Auth.js ---
AUTH_SECRET=
# En local: http://localhost:3000
# En Vercel/producción: https://pawpatroll.vercel.app (o tu dominio)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Búsqueda por foto (CLIP local, sin API HF) ---
# Pesos descargados en: .cache/transformers/ (modelo Xenova/clip-vit-base-patch32)
# CLIP_MODEL=Xenova/clip-vit-base-patch32
# CLIP_MIN_COSENO=0.58
# CLIP_GAP_MINIMO=0.03
# CLIP_MAX_FOTOS_INDEX=5
# CLIP_RADIO_KM=25

# --- Google OAuth 2.0 ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Correo PawPatrol (Gmail del admin/soporte) ---
# Cuenta: paw.patrol.soporte@gmail.com
# Crear contraseña de aplicación: Google → Seguridad → Verificación en 2 pasos → Contraseñas de aplicaciones
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=paw.patrol.soporte@gmail.com
SMTP_PASS=
EMAIL_FROM=PawPatrol <paw.patrol.soporte@gmail.com>

# --- Tiempo real (WebSocket, puerto aparte del dev server) ---
WS_PORT=3001
NEXT_PUBLIC_WS_PORT=3001
# Opcional: URL completa (producción con proxy wss)
# NEXT_PUBLIC_WS_URL=wss://tu-dominio.com/ws
