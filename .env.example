# Copia a .env.local:  copy .env.example .env.local

# --- Neon PostgreSQL ---
# En Neon: Dashboard → Connection string → pooled (recomendado para serverless)
DATABASE_URL=postgresql://usuario:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# --- Auth.js (genera con: openssl rand -base64 32) ---
AUTH_SECRET=tu_secreto_largo_aqui

# URL pública de la app (enlaces de verificación de correo)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Google OAuth 2.0 ---
# https://console.cloud.google.com/apis/credentials
# URI autorizada: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Correo (opcional; en dev el enlace se imprime en consola) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=PawPatrol <noreply@tudominio.com>
