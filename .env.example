# Copia a .env.local:  copy .env.example .env.local

# --- Neon PostgreSQL ---
DATABASE_URL=

# --- Auth.js ---
AUTH_SECRET=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Google OAuth 2.0 ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Correo PawPatrol (Gmail del admin/soporte) ---
# Cuenta: paw.patrol.soporte@gmail.com
# Crear contraseña de aplicación: Google → Seguridad → Verificación en 2 pasos → Contraseñas de aplicaciones
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=paw.patrol.soporte@gmail.com
SMTP_PASS=
EMAIL_FROM=PawPatrol <paw.patrol.soporte@gmail.com>
