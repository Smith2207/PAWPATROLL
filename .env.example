# --- Búsqueda por foto (Gemini Flash + Embedding 2, 768d) ---
# Vercel / org sin API keys: ADC con cuenta de servicio (JSON en una línea).
GOOGLE_CLOUD_PROJECT=tu-proyecto-id
GOOGLE_CLOUD_LOCATION=us-central1
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account",...}
#
# Local: gcloud auth application-default login (no hace falta el JSON)
#
# GEMINI_VISION_MODEL=gemini-1.5-flash
# GEMINI_EMBEDDING_MODEL=gemini-embedding-2
# GEMINI_EMBEDDING_DIMENSION=768
# VISUAL_PROVIDER=gemini
# VISUAL_MIN_COSENO=0.58
# VISUAL_GAP_MINIMO=0.03
# VISUAL_MAX_FOTOS_INDEX=5
# VISUAL_RADIO_KM=25
#
# Tras activar Gemini: npm run db:migrate-gemini-768 && npm run db:reindexar-visual
#
# Respaldo sin Google: VISUAL_PROVIDER=clip
