# --- Base de datos (Neon PostgreSQL) ---
DATABASE_URL=postgresql://usuario:pass@ep-xxx.neon.tech/neondb?sslmode=require

# --- Auth.js ---
AUTH_SECRET=genera-con-openssl-rand-base64-32
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Google OAuth (opcional) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# --- Correo SMTP (opcional; sin SMTP los enlaces se imprimen en consola) ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM=PawPatrol <soporte@ejemplo.com>

# --- Búsqueda por foto (Gemini Agent Platform + Embedding 768d) ---
GOOGLE_CLOUD_PROJECT=tu-proyecto-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_ENTERPRISE=true
#
# Local: ruta relativa al JSON de cuenta de servicio (NO pegar JSON multilínea aquí)
# GOOGLE_APPLICATION_CREDENTIALS=secrets/gcp-sa.json
#
# Vercel: mismo JSON en una sola línea
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account",...}
#
# Modelos en Agent Platform (habilita Agent Platform API en GCP):
# GEMINI_VISION_MODEL=gemini-2.5-flash
# GEMINI_EMBEDDING_MODEL=gemini-embedding-2-preview
# GEMINI_EMBEDDING_DIMENSION=768
# VISUAL_PROVIDER=gemini
#
# Tras activar: npm run db:migrate-gemini-768 && npm run db:reindexar-visual
#
# Respaldo sin Google: VISUAL_PROVIDER=clip
#
# --- Tiempo real (guía completa: docs/TIEMPO-REAL-VERCEL.md) ---
# Local: npm run dev (WS en :3001). Opcional: npm run ws:prod
#
# Vercel + Railway (recomendado para instantáneo):
#   Railway Root Directory: services/pawpatroll-ws  →  npm start
#   Railway: WS_PUBLISH_SECRET=...
#   Vercel:
#     NEXT_PUBLIC_WS_URL=wss://tu-app.up.railway.app
#     WS_PUBLISH_URL=https://tu-app.up.railway.app/publish
#     WS_PUBLISH_SECRET=(igual que Railway; también firma tokens /api/ws/token)
#
# Solo Vercel (sin Railway): no definas estas variables; chat ~8s, mapa ~90s.
#
# --- Ubicación / mapas (opcional: direcciones y búsqueda de lugares en Perú) ---
# Crea una API key en Google Cloud y activa: Places API + Geocoding API.
# En «Restricciones de API» de la key, marca Places API y Geocoding API.
# Tras cambiar APIs o .env.local, reinicia: npm run dev
# El botón Ubicarme usa solo GPS del navegador (no hace falta Geolocation API).
# GOOGLE_MAPS_API_KEY=tu-api-key
# Opcional: mini mapas en burbujas de chat (Static Maps API)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=tu-api-key
#
# --- Vercel Blob (adjuntos chat privados + fotos de ficha públicas) ---
# Storage → Connect Project → prefix BLOB → read-write token (Sensitive)
# Local: copia BLOB_READ_WRITE_TOKEN desde Vercel (Settings → Environment Variables)
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
